# ==================================================
# ШАБЛОН НАСТРОЕК ДЛЯ MAX-БОТА
# Скопируйте этот файл как .env и заполните реальными данными
# ==================================================

# ------------------ База Moodle (MariaDB) ------------------
MOODLE_DB_HOST=localhost
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=your_db_name
MOODLE_DB_USER=your_db_user
MOODLE_DB_PASSWORD=your_moodle_db_password_here

# ------------------ База расписания (MS SQL) ------------------
SCHEDULE_DB_SERVER=192.168.x.x          # IP или домен сервера MS SQL
SCHEDULE_DB_PORT=1433
SCHEDULE_DB_NAME=your_db_name               # Имя базы данных расписания
SCHEDULE_DB_USER=your_db_user
SCHEDULE_DB_PASSWORD=your_schedule_db_password_here

# ------------------ Локальная база бота (PostgreSQL) ------------------
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=your_db_name
LOCAL_DB_USER=your_db_user
LOCAL_DB_PASSWORD=your_local_db_password_here

# ------------------ Токен бота MAX ------------------
MAX_BOT_TOKEN=your_max_bot_token_here

# ------------------ Секретный ключ Flask ------------------
APP_SECRET=very_long_random_string_change_in_production

# ------------------ Режим отладки (False для продакшена) ------------------
DEBUG=False

# ------------------ Дополнительные пути (можно не менять) ------------------
PROJECT_DIR=/opt/max_bot
LOG_FILE=/opt/max_bot/logs/app.log
BACKUP_DIR_BOT=/opt/max_bot/backups