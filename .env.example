# ШАБЛОН НАСТРОЕК - скопируй как .env и заполни

# База Moodle (MariaDB) - только чтение
MOODLE_DB_HOST=хост_бд_moodle
MOODLE_DB_PORT=3306
MOODLE_DB_NAME=имя_бд_moodle
MOODLE_DB_USER=пользователь_только_чтение
MOODLE_DB_PASSWORD=пароль_пользователя

# База расписания (MS SQL) - только чтение
SCHEDULE_DB_SERVER=хост_бд_расписания
SCHEDULE_DB_PORT=1433
SCHEDULE_DB_NAME=имя_бд_расписания
SCHEDULE_DB_USER=пользователь_только_чтение
SCHEDULE_DB_PASSWORD=пароль_пользователя

# Локальная база данных бота (PostgreSQL)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=имя_бд_бота
LOCAL_DB_USER=пользователь_бд_бота
LOCAL_DB_PASSWORD=пароль_пользователя_бд_бота

# Токен бота в MAX (получается в личном кабинете разработчика)
MAX_BOT_TOKEN=ваш_токен_бота

# Секретный ключ приложения Flask
APP_SECRET=случайная_длинная_строка

# Режим отладки (False для продакшена)
DEBUG=False